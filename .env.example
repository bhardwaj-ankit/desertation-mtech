# Configuration Template
# Copy to .env and fill in your values

# ============ LLM Configuration ============
LLM_MODEL_NAME=mistralai/Mistral-7B-v0.1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_DEVICE=cpu  # Options: cpu, cuda, mps

# ============ Embeddings ============
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============ Vector Database ============
VECTOR_DB_TYPE=chroma  # Options: chroma, faiss, weaviate, milvus
VECTOR_DB_PATH=./data/vector_db
VECTOR_DB_COLLECTION=techlog_documents

# ============ RAG Configuration ============
RAG_RETRIEVAL_K=5
RAG_RETRIEVAL_THRESHOLD=0.5
RAG_CONFIDENCE_THRESHOLD=0.70  # Below this: abstain
RAG_RERANK_ENABLED=true

# ============ Data Paths ============
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
MODELS_PATH=./models
LOGS_PATH=./logs

# ============ Training Configuration ============
BATCH_SIZE=32
LEARNING_RATE=0.001
NUM_EPOCHS=50
EARLY_STOPPING_PATIENCE=5
VALIDATION_SPLIT=0.1
TEST_SPLIT=0.1
RANDOM_SEED=42

# ============ Model Paths ============
TRIAGE_MODEL_PATH=./models/triage_classifier.pth
RECURRENCE_MODEL_PATH=./models/recurrence_predictor.pth
LORA_MODEL_PATH=./models/lora_adapters

# ============ API Configuration ============
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ============ Streamlit Configuration ============
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501

# ============ Experiment Tracking ============
WANDB_PROJECT=techlog-copilot
WANDB_ENTITY=your-username
WANDB_ENABLED=true

# ============ Logging ============
LOG_LEVEL=INFO
LOG_FORMAT=json  # Options: json, text
AUDIT_LOG_PATH=./logs/audit_trail.json

# ============ Optional: Cloud LLM APIs ============
# If using OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# If using Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# If using Cohere
COHERE_API_KEY=

# ============ Optional: Vector DB Cloud ============
# For Weaviate Cloud
WEAVIATE_CLOUD_URL=
WEAVIATE_API_KEY=

# For Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# ============ Evaluation ============
EVAL_METRICS=[accuracy,precision,recall,f1,auroc,auprc]
EVAL_OUTPUT_PATH=./logs/evaluation_results.json

# ============ Safety & Compliance ============
SAFETY_CONFIDENCE_MIN=0.50
SAFETY_CONFIDENCE_ABSTAIN=0.70
SAFETY_ABSTENTION_ENABLED=true
AUDIT_TRAIL_ENABLED=true

# ============ Performance ============
NUM_WORKERS=4  # For data loading
MIXED_PRECISION=false  # Use fp16 training
GRADIENT_ACCUMULATION_STEPS=1
